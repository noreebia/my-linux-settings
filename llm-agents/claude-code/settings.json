{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Edit(./.claude/**)",
      "Write",
      "Write(./.claude/**)",
      "WebFetch",
      "WebSearch",
      "Agent",
      "mcp__wrike",
      "mcp__plugin_slack_slack",
      "mcp__plugin_playwright_playwright",
      "mcp__claude_ai_Gmail",
      "mcp__claude_ai_Google_Calendar",
      "mcp__ide",
      "mcp__excalidraw",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools",
      "Skill"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statuslines/default-v3.sh"
  }
}
